---
import LS from "@material-design-icons/svg/round/light_mode.svg?raw";
---

<div class="cmps-preview" aria-hidden="true" aria-label="This displays the style of the component after the color scheme was generated by the current Material Theme Builder.">
    <div aria-hidden="true" class="h-[1px] my-16 w-full flex bg-outline"></div>

    <div class="bg-surface-container h-16 w-full flex items-center justify-between px-4">
        <span class="text-on-surface title-medium">Header Title</span>
        <div class="cursor-pointer bg-primary-container text-on-primary-container rounded-full p-2 grid place-content-center">
            <md-icon aria-hidden="true" set:html={LS} />
        </div>
    </div>

    <div class="w-full bg-error-container px-4 py-6 flex flex-col rounded-md">
        <span class="text-on-error-container headline-medium">Error Container</span>
        <span class="text-on-error-container body-medium mt-4">This is an error container. It uses the error color scheme.</span>
    </div>

    <div class="flex flex-col bg-surface-container rounded-3xl pt-4">
        <div class="headline-medium px-6">Title</div>
        <div class="body-medium mt-4 px-6">Description</div>
        <div class="bg-outline-variant h-px mt-4"></div>
        <div class="flex justify-end items-center mt-4 select-none body-medium px-4 mb-4">
            <div class="rounded-full h-12 grid place-content-center cursor-pointer px-4 hover:bg-on-surface/8 active:bg-on-surface/18">Cancel</div>
            <div class="rounded-full h-12 grid place-content-center cursor-pointer px-4 hover:bg-on-surface/8 active:bg-on-surface/18">Apply</div>
        </div>
    </div>

    <div class="flex flex-col gap-[2px] h-fit">
        <div class="bg-surface-container-low p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary hover:bg-primary/92 active:bg-primary/82 text-on-primary">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary hover:bg-primary/92 active:bg-primary/82 text-on-primary">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary hover:bg-primary/92 active:bg-primary/82 text-on-primary">Apply</div>
        </div>
        <div class="bg-surface-container-low p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary hover:bg-secondary/92 active:bg-secondary/82 text-on-secondary">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary hover:bg-secondary/92 active:bg-secondary/82 text-on-secondary">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary hover:bg-secondary/92 active:bg-secondary/82 text-on-secondary">Apply</div>
        </div>
        <div class="bg-surface-container-low p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary hover:bg-tertiary/92 active:bg-tertiary/82 text-on-tertiary">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary hover:bg-tertiary/92 active:bg-tertiary/82 text-on-tertiary">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary hover:bg-tertiary/92 active:bg-tertiary/82 text-on-tertiary">Apply</div>
        </div>
    </div>

    <div class="flex flex-col gap-[2px] h-fit">
        <div class="bg-primary p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary-container hover:bg-primary-container/92 active:bg-primary-container/88 text-on-primary-container">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary-container hover:bg-primary-container/92 active:bg-primary-container/88 text-on-primary-container">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-primary-container hover:bg-primary-container/92 active:bg-primary-container/88 text-on-primary-container">Apply</div>
        </div>
        <div class="bg-secondary p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary-container hover:bg-secondary-container/92 active:bg-secondary-container/88 text-on-secondary-container">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary-container hover:bg-secondary-container/92 active:bg-secondary-container/88 text-on-secondary-container">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-secondary-container hover:bg-secondary-container/92 active:bg-secondary-container/88 text-on-secondary-container">Apply</div>
        </div>
        <div class="bg-tertiary p-2 rounded-full select-none flex gap-[2px] h-fit">
            <div class="rounded-l-[24px] rounded-r-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary-container hover:bg-tertiary-container/92 active:bg-tertiary-container/88 text-on-tertiary-container">Apply</div>
            <div class="rounded-[8px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary-container hover:bg-tertiary-container/92 active:bg-tertiary-container/88 text-on-tertiary-container">Apply</div>
            <div class="rounded-l-[8px] rounded-r-[24px] h-[48px] grid place-content-center cursor-pointer px-4 bg-tertiary-container hover:bg-tertiary-container/92 active:bg-tertiary-container/88 text-on-tertiary-container">Apply</div>
        </div>
    </div>
</div>

<style>
    .cmps-preview {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        padding: 12px;
    }
</style>
